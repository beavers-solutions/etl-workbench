# Used only with compose.local.yaml for local path development.
PIPELINE_ROOT=./example-pipeline

# Optional environment file owned by the pipeline.
PIPELINE_ENV_FILE=./pipeline.env

# Optional image containing pipeline-specific dependencies.
AIRFLOW_IMAGE=etl-workbench:local

AIRFLOW_UI_PORT=18080
AIRFLOW_UI_HOST=127.0.0.1
MINIO_API_PORT=59000
MINIO_CONSOLE_PORT=59001
ETL_LOCAL_BUCKET=etl-local

# Optional development-only MinIO KMS key, when a pipeline requires SSE-S3.
MINIO_KMS_SECRET_KEY=

# Override these with Airflow connection URIs or JSON for external services.
# AIRFLOW_CONN_LOCAL_POSTGRES=postgresql://user:password@db.example:5432/database
# AIRFLOW_CONN_LOCAL_S3={"conn_type":"aws","login":"access-key","password":"secret-key","extra":{"endpoint_url":"https://objects.example","region_name":"eu-west-1"}}
